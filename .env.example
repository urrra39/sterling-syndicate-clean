# The Sterling Syndicate — local development environment
# Copy to .env and change secrets before any real use.

POSTGRES_USER=sterling
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sterling
DATABASE_URL=postgresql+psycopg://sterling:change_me_strong_password@localhost:5432/sterling

JWT_SECRET_KEY=dev-local-secret-key-change-before-prod-32c
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Fernet key for at-rest encryption of sensitive fields (client_display_name,
# lead.raw_text, lead.url, contract.execution_draft).
# Empty = no-op (plaintext). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production — a missing/malformed key hard-fails backend startup.
FIELD_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ENVIRONMENT=development
# Trust X-Forwarded-For only behind a reverse proxy (Render sets this true).
TRUST_PROXY=false
# If set, POST /auth/signup requires matching invite_code in the JSON body.
SIGNUP_INVITE_CODE=
# Prefer 1 locally / on free tiers — in-memory rate limits are per-process.
UVICORN_WORKERS=1

# Payment step-up authorization (kill-switch release hardening)
# When true, POST /confirm-payment requires an approver/owner role AND a valid
# TOTP step-up code. Leave false for the single-operator dev flow.
# NOTE: if PAYMENT_STEPUP_TOTP_SECRET is non-empty, step-up is forced ON automatically.
PAYMENT_STEPUP_REQUIRED=false
# Base32 TOTP secret for the step-up MFA challenge (e.g. from an authenticator app).
# Generate: python -c "import secrets,base64; print(base64.b32encode(secrets.token_bytes(20)).decode())"
PAYMENT_STEPUP_TOTP_SECRET=
# HMAC-SHA256 secret the payment provider signs webhooks with (X-Payment-Signature).
# Empty disables the /leads/{id}/payment-webhook endpoint.
PAYMENT_WEBHOOK_SECRET=

# Frontend base URL for password-reset links
FRONTEND_URL=http://localhost:5173

# SMTP (Gmail) for password-reset email. Use a Gmail App Password, not your login.
# If left blank, reset links are logged to the API console (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Dual LLM routing (override with newer model IDs when your account has them)
OPENAI_API_KEY=
OPENAI_WRITER_MODEL=gpt-4o
OPENAI_EXECUTION_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_SCOUT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIER2_MODEL=claude-sonnet-4-20250514

# Alerts (notification only — never auto-send)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Scout
SCOUT_INTERVAL_MIN_MINUTES=30
SCOUT_INTERVAL_MAX_MINUTES=45
SCOUT_JITTER_MIN_SECONDS=2
SCOUT_JITTER_MAX_SECONDS=12
# Optional Redis — shared rate limits + idempotency across workers (empty = memory)
REDIS_URL=

# Sandbox / DinD
DOCKER_HOST=
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_NODE_IMAGE=node:20-slim
SANDBOX_RUST_IMAGE=rust:1.83-slim
# Keep false — subprocess fallback is NOT a security boundary.
SANDBOX_ALLOW_SUBPROCESS_FALLBACK=false
CAPTCHA_SCREENSHOT_DIR=./data/captcha_pauses

# Residential proxy — Uzbekistan geolocation
RESIDENTIAL_PROXY_URL=
RESIDENTIAL_PROXY_USERNAME=
RESIDENTIAL_PROXY_PASSWORD=
RESIDENTIAL_PROXY_COUNTRY=UZ
RESIDENTIAL_PROXY_REQUIRED=false
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_TIMEZONE=Asia/Tashkent
PLAYWRIGHT_USER_AGENT=
SECRETS_SCRUBBER_ENABLED=true

DLQ_POLL_SECONDS=15
FOLLOW_UP_AFTER_HOURS=48
ARCHIVE_AFTER_DAYS=7
FOLLOWUP_POLL_SECONDS=3600

BACKEND_PORT=8000
FRONTEND_PORT=5173
CHROMA_PERSIST_DIR=./data/chroma_db
GITHUB_TOKEN=
BASE_HOURLY_RATE=75
MIN_BID=150
MAX_BID=25000
HIGH_MATCH_THRESHOLD=0.72
EMBEDDING_MODEL=hashing-384
